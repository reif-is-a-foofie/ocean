# Example environment variables
ENV=development
PORT=8000

# User Gemini (preferred for all Gemini API calls once set)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Release builds only: CI sets this once, then runs
#   python scripts/embed_release_gemini_key.py
# to bake a setup-only key into ocean/_release_embedded.py before packaging.
# OCEAN_RELEASE_GEMINI_KEY=

# Optional: disable pooled setup key in a packaged build
# OCEAN_DISABLE_EMBEDDED_GEMINI=1

# Daily cap on embedded-setup Gemini calls per machine (default 48)
# OCEAN_EMBEDDED_GEMINI_DAILY_CAP=48

